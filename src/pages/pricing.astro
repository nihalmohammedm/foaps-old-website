---
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
import SectionHeader from "../components/SectionHeader.astro";
import CTABanner from "../components/CTABanner.astro";


const faqItems = [
  {
    q: "Is there a free trial?",
    a: "Yes! You can sign up and use Foaps for free during the trial period. No credit card required.",
  },
  {
    q: "Can I change my plan later?",
    a: "Absolutely. You can upgrade or downgrade your plan at any time from your account settings.",
  },
  {
    q: "Are there any hidden charges?",
    a: "No. Our plans are simple, transparent, and reasonable. We charge only for what is provided and no extra/hidden charges are incurred.",
  },
  {
    q: "Do you offer discounts for annual billing?",
    a: "Yes, annual billing comes with a discount compared to monthly pricing. Contact us for details.",
  },
];
---

<Layout
  title="Restaurant Order Management Software Pricing in India – Foaps"
  description="Our plans are simple, transparent, and reasonable to suit your requirements. We charge only for what is provided and no extra/hidden charges are incurred."
>
  <Navbar />
  <main>
    <section class="pricing-hero">
      <div class="container">
        <SectionHeader
          eyebrow="Pricing"
          title="Only pay for what is delivered. Nothing more."
          subtitle="Our plans are simple, transparent, and reasonable, curated to suit your requirements. We charge only for what is provided and no extra/hidden charges are incurred. All you need to do is choose the right plan ideal for your restaurant!"
        />
      </div>
    </section>

    <section class="pricing-comparison">
      <div class="container">
        <img src="/assets/llborder.png" alt="" aria-hidden="true" class="pricing-divider" loading="lazy" />
        <div class="pricing-comparison__row">
          <div class="pricing-option">
            <span class="pricing-option__amount">₹798</span>
            <span class="pricing-option__label">Monthly per platform</span>
          </div>
          <div class="pricing-or">OR</div>
          <div class="pricing-option">
            <span class="pricing-option__amount">₹6420</span>
            <span class="pricing-option__label">Annually per platform</span>
            <span class="pricing-option__save">(Save 33% on annual billing)</span>
          </div>
        </div>
        <img src="/assets/llborder.png" alt="" aria-hidden="true" class="pricing-divider" loading="lazy" />
        <p class="pricing-note">No Credit Card Required. 30-Day Free Trial</p>
        <a href="https://receiver.orderpipe.co/v2/#/signup" class="btn btn-primary pricing-cta">Start Free Trial</a>
      </div>
    </section>

    <section class="faq">
      <div class="container faq__inner">
        <SectionHeader eyebrow="FAQ" title="Frequently asked questions" showLine={false} />
        <ul class="faq__list">
          {
            faqItems.map((item) => (
              <li class="faq__item">
                <h4 class="faq__question">{item.q}</h4>
                <p class="faq__answer">{item.a}</p>
              </li>
            ))
          }
        </ul>
      </div>
    </section>

    <CTABanner
      title="Still have questions? Talk to our team."
      subtitle="We'd love to help you find the right plan for your restaurant."
      secondaryLabel="Contact Us"
      secondaryHref="mailto:hello@foaps.co"
    />
  </main>
  <Footer />
</Layout>

<style>
  .pricing-hero {
    padding: 80px 0 40px;
    background: linear-gradient(135deg, #fff9f7 0%, #fff 60%);
  }

  .pricing-comparison {
    padding: 20px 0 80px;
    text-align: center;
  }

  .pricing-divider {
    width: 100%;
    height: auto;
    opacity: 0.25;
    display: block;
    margin: 32px 0;
  }

  .pricing-comparison__row {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 60px;
  }

  .pricing-option {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
  }

  .pricing-option__amount {
    font-size: clamp(40px, 6vw, 72px);
    font-weight: 700;
    color: var(--color-heading);
    line-height: 1;
  }

  .pricing-option__label {
    font-size: 18px;
    color: var(--color-muted);
  }

  .pricing-option__save {
    font-size: 15px;
    color: var(--color-accent);
  }

  .pricing-or {
    width: 72px;
    height: 72px;
    border-radius: 50%;
    background: var(--color-heading);
    color: #fff;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 18px;
    font-weight: 700;
    flex-shrink: 0;
  }

  .pricing-note {
    font-size: 17px;
    color: var(--color-muted);
    margin: 32px 0 24px;
  }

  .pricing-cta {
    padding: 0 48px;
    height: 52px;
    font-size: 16px;
  }

  .faq {
    padding: 80px 0;
    background: var(--color-light-bg);
  }

  .faq__inner {
    max-width: 780px;
  }

  .faq__list {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .faq__item {
    padding: 28px 0;
    border-bottom: 1px solid #eee;
  }

  .faq__item:first-child {
    border-top: 1px solid #eee;
  }

  .faq__question {
    font-size: 18px;
    font-weight: 600;
    color: var(--color-primary);
    margin-bottom: 10px;
  }

  .faq__answer {
    font-size: 15px;
    color: var(--color-muted);
    line-height: 1.7;
  }

  @media (max-width: 600px) {
    .pricing-comparison__row {
      flex-direction: column;
      gap: 32px;
    }
  }
</style>
