---
const columns = [
  {
    title: "Company",
    links: [
      { label: "About Us", href: "/about-us" },
      { label: "Privacy", href: "/privacy-policies" },
      { label: "Terms & Conditions", href: "/terms-and-conditions" },
      { label: "License Agreement", href: "/license-agreement" },
    ],
  },
  {
    title: "Product",
    links: [
      { label: "Why Foaps", href: "/why-foaps" },
      { label: "Order Management", href: "/order-management" },
      { label: "Menu Management", href: "/menu-management" },
      { label: "In-depth Reports", href: "/in-depth-reports" },
    ],
  },
  {
    title: "Sales",
    links: [
      { label: "Pricing", href: "/pricing" },
      // { label: "Request Demo", href: "/request-demo" },
    ],
  },
  {
    title: "Resources",
    links: [
      { label: "Blog", href: "/blog" },
      { label: "Success Stories", href: "/customers" },
      { label: "Help & Support", href: "/help-support" },
      { label: "Restaurant Order Management", href: "/restaurant-order-management-system" },
    ],
  },
  {
    title: "Connect",
    links: [
      { label: "hello@foaps.co", href: "mailto:hello@foaps.co" },
      { label: "Facebook", href: "https://www.facebook.com/foaps/" },
      { label: "LinkedIn", href: "https://in.linkedin.com/company/foaps" },
      { label: "Instagram", href: "https://www.instagram.com/foaps.co/" },
      { label: "Twitter", href: "https://twitter.com/Foapsdotco" },
    ],
  },
];
---

<footer class="site-footer">
  <div class="site-footer__top">
    <div class="container site-footer__top-inner">
      <div class="site-footer__brand">
        <a href="/" aria-label="Foaps home">
          <img src="/assets/foaps-logo.svg" alt="Foaps" width="110" height="34" class="site-footer__logo" />
        </a>
      </div>

      <nav class="site-footer__nav" aria-label="Footer navigation">
        {
          columns.map((col) => (
            <div class="site-footer__col">
              <h5 class="site-footer__col-title">{col.title}</h5>
              <ul>
                {col.links.map((link) => (
                  <li>
                    <a href={link.href} class="site-footer__link">
                      {link.label}
                    </a>
                  </li>
                ))}
              </ul>
            </div>
          ))
        }
      </nav>
    </div>
  </div>

  <div class="site-footer__bottom">
    <div class="container site-footer__bottom-inner">
      <p class="site-footer__copy">
        &copy; {new Date().getFullYear()} Foaps. All rights reserved.
      </p>
      <ul class="site-footer__legal">
        <li><a href="/privacy-policies">Privacy</a></li>
        <li><a href="/help-support">Security</a></li>
        <li><a href="/terms-and-conditions">Terms</a></li>
      </ul>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    background: #1a1a1a;
    color: #aaa;
  }

  .site-footer__top {
    padding: 80px 0 60px;
  }

  .site-footer__top-inner {
    display: grid;
    grid-template-columns: 200px 1fr;
    gap: 60px;
    align-items: start;
  }

  .site-footer__logo {
    filter: brightness(0) invert(1);
    display: block;
  }

  .site-footer__nav {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 32px;
  }

  .site-footer__col-title {
    color: #fff;
    font-size: 13px;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    margin-bottom: 22px;
  }

  .site-footer__col ul {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .site-footer__link {
    color: #888;
    font-size: 14px;
    font-weight: 300;
    line-height: 1.5;
    transition: color 0.2s;
  }

  .site-footer__link:hover {
    color: var(--color-accent);
  }

  .site-footer__bottom {
    border-top: 1px solid #2e2e2e;
    padding: 22px 0;
  }

  .site-footer__bottom-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 12px;
  }

  .site-footer__copy {
    font-size: 14px;
    color: #555;
    font-weight: 300;
  }

  .site-footer__legal {
    display: flex;
    gap: 28px;
  }

  .site-footer__legal a {
    font-size: 14px;
    color: #555;
    font-weight: 300;
    transition: color 0.2s;
  }

  .site-footer__legal a:hover {
    color: var(--color-accent);
  }

  @media (max-width: 1024px) {
    .site-footer__top-inner {
      grid-template-columns: 1fr;
      gap: 40px;
    }

    .site-footer__nav {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  @media (max-width: 640px) {
    .site-footer__nav {
      grid-template-columns: repeat(2, 1fr);
    }

    .site-footer__bottom-inner {
      flex-direction: column;
      text-align: center;
    }
  }
</style>
