---
const testimonials = [
  {
    quote:
      "Foaps has completely transformed how we manage our orders. We no longer miss any orders from Swiggy or Zomato. Everything is in one place and it's super easy to use.",
    name: "Geethu",
    role: "Haji Ali",
    avatar: "/assets/avatar.svg",
  },
  {
    quote:
      "Managing orders from multiple platforms was a nightmare before Foaps. Now we handle everything from a single screen. Our efficiency has gone up significantly.",
    name: "Sathar",
    role: "Mallus Dhaba",
    avatar: "/assets/avatar.svg",
  },
  {
    quote:
      "The menu management feature is a game changer. I update once and it reflects everywhere. Saved us so much time every day.",
    name: "Razeen",
    role: "Ceylone Bake House",
    avatar: "/assets/avatar.svg",
  },
];
---

<section class="testimonials">
  <div class="container">
    <div class="testimonials__header">
      <h2>Loved and believed by people beyond boundaries!</h2>
      <img src="/assets/line-decoration.svg" alt="" aria-hidden="true" width="250" height="30" loading="lazy" />
    </div>

    <ul class="testimonials__grid">
      {
        testimonials.map((t) => (
          <li class="testimonial-card">
            <div class="testimonial-card__deco" aria-hidden="true">
              <img src="/assets/shape-141.svg" alt="" width="60" height="54" loading="lazy" />
            </div>
            <blockquote class="testimonial-card__quote">"{t.quote}"</blockquote>
            <div class="testimonial-card__footer">
              <img
                src={t.avatar}
                alt={t.name}
                width="50"
                height="50"
                class="testimonial-card__avatar"
                loading="lazy"
              />
              <div>
                <p class="testimonial-card__name">{t.name}</p>
                <p class="testimonial-card__role">{t.role}</p>
              </div>
            </div>
          </li>
        ))
      }
    </ul>
  </div>
</section>

<style>
  .testimonials {
    background: linear-gradient(135deg, #fff5f4 0%, #fff 60%);
  }

  .testimonials__header {
    text-align: center;
    margin-bottom: 50px;
  }

  .testimonials__header h2 {
    margin-bottom: 14px;
  }

  .testimonials__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 28px;
  }

  .testimonial-card {
    background: #fff;
    border-radius: 12px;
    padding: 36px 32px 28px;
    box-shadow: 0 5px 25px rgba(0, 0, 0, 0.06);
    border: 1px solid #f0eded;
    position: relative;
    overflow: hidden;
    transition: box-shadow 0.25s, transform 0.25s;
  }

  .testimonial-card:hover {
    box-shadow: 0 12px 40px rgba(249, 111, 96, 0.12);
    transform: translateY(-4px);
  }

  .testimonial-card__deco {
    position: absolute;
    top: -8px;
    right: -8px;
    opacity: 0.07;
  }

  .testimonial-card__quote {
    font-size: 16px;
    line-height: 1.75;
    color: var(--color-muted);
    font-weight: 300;
    font-style: normal;
    margin-bottom: 28px;
  }

  .testimonial-card__footer {
    display: flex;
    align-items: center;
    gap: 14px;
    padding-top: 20px;
    border-top: 1px solid #f5f5f5;
  }

  .testimonial-card__avatar {
    width: 50px;
    height: 50px;
    border-radius: 50%;
    object-fit: cover;
    background: #f0f0f0;
    flex-shrink: 0;
  }

  .testimonial-card__name {
    font-size: 15px;
    font-weight: 600;
    color: var(--color-heading);
    margin-bottom: 2px;
  }

  .testimonial-card__role {
    font-size: 13px;
    color: #aaa;
    font-weight: 400;
  }

  @media (max-width: 900px) {
    .testimonials__grid {
      grid-template-columns: 1fr 1fr;
    }
  }

  @media (max-width: 580px) {
    .testimonials__grid {
      grid-template-columns: 1fr;
    }
  }
</style>
