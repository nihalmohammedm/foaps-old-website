---
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
import SectionHeader from "../components/SectionHeader.astro";
---

<Layout
  title="Request a Demo – Foaps Restaurant Order Management"
  description="See Foaps in action. Book a free demo with our team and learn how Foaps can help your restaurant manage orders, menus, and get actionable insights."
>
  <Navbar />
  <main>
    <section class="demo-page">
      <div class="container demo-page__inner">
        <div class="demo-page__content">
          <SectionHeader
            eyebrow="Get a Demo"
            title="See Foaps in action"
            subtitle="Book a free, no-obligation demo and our team will show you exactly how Foaps can work for your restaurant."
            align="left"
            showLine={false}
          />

          <ul class="demo-benefits">
            {
              [
                "Live walkthrough of the Foaps dashboard",
                "Learn how to integrate your delivery platforms",
                "See real-time menu management in action",
                "Understand the reporting & analytics features",
                "Get your questions answered by our team",
              ].map((b) => (
                <li class="demo-benefit">
                  <svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
                    <circle cx="9" cy="9" r="9" fill="#ff6b28" />
                    <path d="M5 9l3 3 5-5" stroke="#fff" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
                  </svg>
                  {b}
                </li>
              ))
            }
          </ul>
        </div>

        <div class="demo-page__form">
          <div class="demo-form-card">
            <h3 class="demo-form-card__title">Book your free demo</h3>
            <form class="demo-form" id="demo-form" novalidate>
              <div class="demo-form__field">
                <label for="name">Full Name *</label>
                <input type="text" id="name" name="name" placeholder="Your name" required />
              </div>
              <div class="demo-form__field">
                <label for="email">Email Address *</label>
                <input type="email" id="email" name="email" placeholder="you@restaurant.com" required />
              </div>
              <div class="demo-form__field">
                <label for="phone">Phone Number *</label>
                <input type="tel" id="phone" name="phone" placeholder="+91 98765 43210" required />
              </div>
              <div class="demo-form__field">
                <label for="restaurant">Restaurant Name *</label>
                <input type="text" id="restaurant" name="restaurant" placeholder="Your restaurant name" required />
              </div>
              <div class="demo-form__field">
                <label for="outlets">Number of Outlets</label>
                <select id="outlets" name="outlets">
                  <option value="">Select...</option>
                  <option value="1">1 outlet</option>
                  <option value="2-5">2–5 outlets</option>
                  <option value="6-10">6–10 outlets</option>
                  <option value="10+">More than 10</option>
                </select>
              </div>
              <div class="demo-form__field">
                <label for="message">Anything specific you'd like to know?</label>
                <textarea id="message" name="message" rows="3" placeholder="Optional message..."></textarea>
              </div>
              <button type="submit" class="btn btn-primary demo-form__submit">
                Book My Demo
              </button>
              <p class="demo-form__note">We'll get back to you within 1 business day.</p>
            </form>
          </div>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>

<style>
  .demo-page {
    padding: 80px 0;
    background: linear-gradient(135deg, #fff9f7 0%, #fff 60%);
    min-height: calc(100vh - 72px);
  }

  .demo-page__inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    align-items: start;
    gap: 64px;
  }

  .demo-benefits {
    display: flex;
    flex-direction: column;
    gap: 14px;
    margin-top: 32px;
  }

  .demo-benefit {
    display: flex;
    align-items: center;
    gap: 12px;
    font-size: 15px;
    color: var(--color-primary);
    font-weight: 500;
  }

  .demo-benefit svg {
    flex-shrink: 0;
  }

  .demo-form-card {
    background: var(--color-white);
    border-radius: 20px;
    padding: 40px;
    box-shadow: 0 8px 40px rgba(0, 0, 0, 0.08);
    border: 1px solid #f0f0f0;
  }

  .demo-form-card__title {
    font-size: 22px;
    font-weight: 700;
    color: var(--color-primary);
    margin-bottom: 28px;
  }

  .demo-form {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .demo-form__field {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .demo-form__field label {
    font-size: 13px;
    font-weight: 600;
    color: var(--color-primary);
  }

  .demo-form__field input,
  .demo-form__field select,
  .demo-form__field textarea {
    padding: 12px 16px;
    border: 1px solid #ddd;
    border-radius: 8px;
    font-size: 15px;
    font-family: var(--font-base);
    color: var(--color-primary);
    outline: none;
    transition: border-color 0.15s;
    background: #fff;
  }

  .demo-form__field input:focus,
  .demo-form__field select:focus,
  .demo-form__field textarea:focus {
    border-color: var(--color-accent);
  }

  .demo-form__field textarea {
    resize: vertical;
    min-height: 80px;
  }

  .demo-form__submit {
    width: 100%;
    padding: 16px;
    font-size: 16px;
  }

  .demo-form__note {
    font-size: 12px;
    color: #aaa;
    text-align: center;
  }

  @media (max-width: 900px) {
    .demo-page__inner {
      grid-template-columns: 1fr;
      gap: 40px;
    }
  }
</style>
