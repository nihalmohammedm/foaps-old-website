---
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
import SectionHeader from "../components/SectionHeader.astro";
import CTABanner from "../components/CTABanner.astro";

const plans = [
  {
    name: "Starter",
    price: "₹999",
    period: "/month",
    description: "Perfect for single-outlet restaurants just getting started with online orders.",
    features: [
      "1 restaurant outlet",
      "Up to 3 delivery platforms",
      "Order management dashboard",
      "Basic menu management",
      "Email support",
    ],
    cta: "Get Started",
    href: "https://receiver.orderpipe.co/v2/#/signup",
    highlighted: false,
  },
  {
    name: "Growth",
    price: "₹2,499",
    period: "/month",
    description: "For growing restaurants that need advanced features and deeper insights.",
    features: [
      "Up to 3 restaurant outlets",
      "Unlimited delivery platforms",
      "Advanced order management",
      "Full menu & pricing sync",
      "In-depth analytics & reports",
      "Priority support",
    ],
    cta: "Start Free Trial",
    href: "https://receiver.orderpipe.co/v2/#/signup",
    highlighted: true,
  },
  {
    name: "Enterprise",
    price: "Custom",
    period: "",
    description: "For multi-chain restaurants and cloud kitchen operators with custom needs.",
    features: [
      "Unlimited outlets",
      "Unlimited delivery platforms",
      "Custom integrations",
      "Dedicated account manager",
      "SLA-backed uptime",
      "Custom reports & API access",
    ],
    cta: "Contact Sales",
    href: "/request-demo",
    highlighted: false,
  },
];

const faqItems = [
  {
    q: "Is there a free trial?",
    a: "Yes! You can sign up and use Foaps for free during the trial period. No credit card required.",
  },
  {
    q: "Can I change my plan later?",
    a: "Absolutely. You can upgrade or downgrade your plan at any time from your account settings.",
  },
  {
    q: "Are there any hidden charges?",
    a: "No. Our plans are simple, transparent, and reasonable. We charge only for what is provided and no extra/hidden charges are incurred.",
  },
  {
    q: "Do you offer discounts for annual billing?",
    a: "Yes, annual billing comes with a discount compared to monthly pricing. Contact us for details.",
  },
];
---

<Layout
  title="Restaurant Order Management Software Pricing in India – Foaps"
  description="Our plans are simple, transparent, and reasonable to suit your requirements. We charge only for what is provided and no extra/hidden charges are incurred."
>
  <Navbar />
  <main>
    <section class="pricing-hero">
      <div class="container">
        <SectionHeader
          eyebrow="Pricing"
          title="Simple, transparent pricing"
          subtitle="Our plans are simple, transparent, and reasonable to suit your requirements. We charge only for what is provided — no hidden fees."
        />
      </div>
    </section>

    <section class="pricing-plans">
      <div class="container">
        <ul class="pricing-plans__grid">
          {
            plans.map((plan) => (
              <li class={`pricing-card ${plan.highlighted ? "pricing-card--highlight" : ""}`}>
                <div class="pricing-card__header">
                  <h3 class="pricing-card__name">{plan.name}</h3>
                  <div class="pricing-card__price">
                    <span class="pricing-card__amount">{plan.price}</span>
                    {plan.period && <span class="pricing-card__period">{plan.period}</span>}
                  </div>
                  <p class="pricing-card__description">{plan.description}</p>
                </div>
                <ul class="pricing-card__features">
                  {plan.features.map((feature) => (
                    <li class="pricing-card__feature">
                      <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                        <path d="M3 8l3.5 3.5L13 4" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
                      </svg>
                      {feature}
                    </li>
                  ))}
                </ul>
                <a href={plan.href} class={`btn ${plan.highlighted ? "btn-primary" : "btn-outline"} pricing-card__cta`}>
                  {plan.cta}
                </a>
              </li>
            ))
          }
        </ul>
      </div>
    </section>

    <section class="faq">
      <div class="container faq__inner">
        <SectionHeader eyebrow="FAQ" title="Frequently asked questions" showLine={false} />
        <ul class="faq__list">
          {
            faqItems.map((item) => (
              <li class="faq__item">
                <h4 class="faq__question">{item.q}</h4>
                <p class="faq__answer">{item.a}</p>
              </li>
            ))
          }
        </ul>
      </div>
    </section>

    <CTABanner
      title="Still have questions? Talk to our team."
      subtitle="We'd love to help you find the right plan for your restaurant."
      primaryLabel="Get a Demo"
      primaryHref="/request-demo"
      secondaryLabel="Contact Us"
      secondaryHref="mailto:hello@foaps.co"
    />
  </main>
  <Footer />
</Layout>

<style>
  .pricing-hero {
    padding: 80px 0 40px;
    background: linear-gradient(135deg, #fff9f7 0%, #fff 60%);
  }

  .pricing-plans {
    padding: 40px 0 80px;
  }

  .pricing-plans__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
    align-items: start;
  }

  .pricing-card {
    border: 1px solid #eee;
    border-radius: 16px;
    padding: 36px 28px;
    background: var(--color-white);
    display: flex;
    flex-direction: column;
    gap: 28px;
  }

  .pricing-card--highlight {
    border-color: var(--color-accent);
    box-shadow: 0 8px 40px rgba(255, 107, 40, 0.15);
    transform: scale(1.03);
  }

  .pricing-card__name {
    font-size: 20px;
    font-weight: 700;
    color: var(--color-primary);
    margin-bottom: 12px;
  }

  .pricing-card__price {
    display: flex;
    align-items: baseline;
    gap: 4px;
    margin-bottom: 12px;
  }

  .pricing-card__amount {
    font-size: 40px;
    font-weight: 700;
    color: var(--color-primary);
  }

  .pricing-card__period {
    font-size: 15px;
    color: var(--color-muted);
  }

  .pricing-card__description {
    font-size: 14px;
    color: var(--color-muted);
    line-height: 1.6;
  }

  .pricing-card__features {
    display: flex;
    flex-direction: column;
    gap: 12px;
    flex: 1;
  }

  .pricing-card__feature {
    display: flex;
    align-items: flex-start;
    gap: 10px;
    font-size: 14px;
    color: var(--color-muted);
    line-height: 1.5;
  }

  .pricing-card__feature svg {
    flex-shrink: 0;
    margin-top: 2px;
    color: var(--color-accent);
  }

  .pricing-card__cta {
    width: 100%;
    text-align: center;
  }

  .faq {
    padding: 80px 0;
    background: var(--color-light-bg);
  }

  .faq__inner {
    max-width: 780px;
  }

  .faq__list {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .faq__item {
    padding: 28px 0;
    border-bottom: 1px solid #eee;
  }

  .faq__item:first-child {
    border-top: 1px solid #eee;
  }

  .faq__question {
    font-size: 18px;
    font-weight: 600;
    color: var(--color-primary);
    margin-bottom: 10px;
  }

  .faq__answer {
    font-size: 15px;
    color: var(--color-muted);
    line-height: 1.7;
  }

  @media (max-width: 900px) {
    .pricing-plans__grid {
      grid-template-columns: 1fr;
      max-width: 480px;
      margin: 0 auto;
    }

    .pricing-card--highlight {
      transform: none;
    }
  }
</style>
