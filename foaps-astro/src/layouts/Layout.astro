---
interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Foaps: Online Restaurant Order Management System in India",
  description = "Manage online food orders from Swiggy, Zomato, Dunzo in a single dashboard, increase restaurant sales with actionable insights, automate menu & pricing updates easily.",
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/assets/foaps-logo.svg" />
    <title>{title}</title>
  </head>
  <body>
    <slot />
  </body>
</html>

<style is:global>
  *,
  *::before,
  *::after {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  @font-face {
    font-family: "Gordita";
    src: url("/assets/fonts/gordita-regular.woff2") format("woff2"),
         url("/assets/fonts/gordita-regular.woff") format("woff");
    font-weight: 400;
    font-style: normal;
    font-display: swap;
  }

  @font-face {
    font-family: "Gordita";
    src: url("/assets/fonts/gordita-medium.woff2") format("woff2"),
         url("/assets/fonts/gordita-medium.woff") format("woff");
    font-weight: 500;
    font-style: normal;
    font-display: swap;
  }

  :root {
    --color-primary: #2a2a2a;
    --color-heading: #101621;
    --color-accent: #f96f60;
    --color-accent-dark: #ff6b28;
    --color-white: #ffffff;
    --color-muted: #6a6a6a;
    --color-light-bg: #f8f8f8;
    --color-border: #e5e5e5;

    --font-base: "Gordita", sans-serif;

    --section-padding: 90px 0;
    --container-max: 1200px;
    --container-padding: 0 40px;
  }

  html {
    font-family: var(--font-base);
    color: var(--color-primary);
    scroll-behavior: smooth;
  }

  body {
    line-height: 1.6;
    overflow-x: hidden;
    background: #fff;
  }

  img {
    max-width: 100%;
    height: auto;
    display: block;
  }

  img[src$="line-decoration.svg"] {
    margin-left: auto;
    margin-right: auto;
  }

  a {
    text-decoration: none;
    color: inherit;
  }

  ul {
    list-style: none;
  }

  .container {
    max-width: var(--container-max);
    margin: 0 auto;
    padding: var(--container-padding);
  }

  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0 42px;
    height: 52px;
    border-radius: 26px;
    font-weight: 500;
    font-size: 16px;
    font-family: var(--font-base);
    cursor: pointer;
    transition: all 0.25s ease-in-out;
    border: none;
    white-space: nowrap;
  }

  .btn-primary {
    background: var(--color-accent);
    color: var(--color-white);
    box-shadow: 0 10px 30px rgba(249, 111, 96, 0.35);
  }

  .btn-primary:hover {
    background: #e05a4c;
    box-shadow: 0 15px 40px rgba(249, 111, 96, 0.5);
    transform: translateY(-2px);
  }

  .btn-outline {
    background: transparent;
    color: var(--color-heading);
    border: 2px solid var(--color-border);
  }

  .btn-outline:hover {
    border-color: var(--color-accent);
    color: var(--color-accent);
    transform: translateY(-2px);
  }

  .btn-light-accent {
    background: rgba(249, 111, 96, 0.08);
    color: var(--color-accent);
    border: 1px solid rgba(249, 111, 96, 0.4);
  }

  .btn-light-accent:hover {
    background: var(--color-accent);
    color: #fff;
  }

  h1, h2, h3, h4, h5, h6 {
    color: var(--color-heading);
    font-weight: 500;
    line-height: 1.3;
  }

  h1 {
    font-size: clamp(34px, 4.5vw, 65px);
    font-weight: 600;
    line-height: 1.15;
  }

  h2 {
    font-size: clamp(26px, 3.5vw, 50px);
    font-weight: 600;
    line-height: 1.2;
  }

  h3 {
    font-size: clamp(20px, 2.5vw, 30px);
    font-weight: 500;
  }

  h4 {
    font-size: clamp(17px, 2vw, 22px);
    font-weight: 500;
  }

  h5 {
    font-size: 14px;
    font-weight: 500;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  p {
    font-size: 17px;
    line-height: 1.75;
    color: var(--color-muted);
    font-weight: 300;
  }

  section {
    padding: var(--section-padding);
  }

  @media (max-width: 1024px) {
    :root {
      --container-padding: 0 24px;
    }
  }

  @media (max-width: 768px) {
    :root {
      --section-padding: 60px 0;
      --container-padding: 0 20px;
    }
  }
</style>
